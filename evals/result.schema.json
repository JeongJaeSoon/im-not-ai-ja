{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Humanize Japanese skill eval result",
  "type": "object",
  "additionalProperties": false,
  "required": ["results"],
  "properties": {
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["case_id", "register", "output", "grade", "findings", "kept", "self_check"],
        "properties": {
          "case_id": {"type": "string"},
          "register": {"type": "string", "enum": ["R0", "R1", "R2", "R3", "R4"]},
          "output": {"type": "string"},
          "grade": {"type": "string", "enum": ["A", "B", "C", "D"]},
          "findings": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "before", "after", "reason"],
              "properties": {
                "id": {"type": "string"},
                "before": {"type": "string"},
                "after": {"type": "string"},
                "reason": {"type": "string"}
              }
            }
          },
          "kept": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["text", "reason"],
              "properties": {
                "text": {"type": "string"},
                "reason": {"type": "string"}
              }
            }
          },
          "self_check": {
            "type": "object",
            "additionalProperties": false,
            "required": ["facts", "modality", "register", "no_invention"],
            "properties": {
              "facts": {"type": "boolean"},
              "modality": {"type": "boolean"},
              "register": {"type": "boolean"},
              "no_invention": {"type": "boolean"}
            }
          }
        }
      }
    }
  }
}
